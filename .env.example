# =========================================================================
# FiguMatch - Ejemplo de Variables de Entorno (.env.example)
#
# Copia este archivo como '.env' en la raíz del proyecto y completa
# los valores con tus credenciales de Supabase y API Football.
# =========================================================================

# -------------------------------------------------------------------------
# Configuración de Supabase (Base de datos, Autenticación y Storage)
# Obtener de: Supabase Dashboard -> Project Settings -> API
# -------------------------------------------------------------------------

# URL de la API del proyecto de Supabase (ej. https://xxxxxxxxxxxx.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública Anon de Supabase (Anon Key)
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-clave-publica-anonima-de-supabase


# -------------------------------------------------------------------------
# Configuración de API Externa (api-football.com)
# Obtener de: https://dashboard.api-sports.io/
# -------------------------------------------------------------------------

# API Key de API Football (x-apisports-key)
EXPO_PUBLIC_API_FOOTBALL_KEY=tu-clave-api-football-key


# -------------------------------------------------------------------------
# Configuración Opcional del Entorno de Desarrollo (Expo)
# -------------------------------------------------------------------------

# Deshabilita advertencias de conflicto de chequeo de navegación en Expo Router
EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK=1